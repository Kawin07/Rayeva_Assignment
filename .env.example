APP_ENV=development
FLASK_ENV=development
SECRET_KEY=replace_with_secure_secret
DATABASE_URL=sqlite:///rayeva.db
ANTHROPIC_API_KEY=replace_with_anthropic_key
LOG_LEVEL=INFO
MAX_CONTENT_LENGTH=1048576
REQUEST_TIMEOUT_SECONDS=20
AI_RETRY_COUNT=3
AI_TIMEOUT_SECONDS=15
RATE_LIMIT_PER_MINUTE=30
WHATSAPP_MESSAGE_MAX_LENGTH=1000
WEBHOOK_SECRET=replace_with_webhook_secret
WEBHOOK_REPLAY_WINDOW_SECONDS=300
AUTH_TOKEN_MAP={"admin-token":{"role":"admin","subject":"admin-1"},"support-token":{"role":"support","subject":"support-1"},"user-token":{"role":"user","subject":"user-1"}}
